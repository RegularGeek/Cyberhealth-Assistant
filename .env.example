# CyberHealth Assistant Environment Configuration
# Copy this file to .env and fill in your actual values

# OpenAI Configuration (Optional - for AI-powered analysis)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Database Configuration
DATABASE_PATH=cyberhealth.db

# Splunk Configuration
SPLUNK_BASE_URL=https://splunk.company.com:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=your_splunk_password
SPLUNK_VERIFY_SSL=False

# Checkpoint Configuration
CHECKPOINT_BASE_URL=https://checkpoint.company.com
CHECKPOINT_USERNAME=admin
CHECKPOINT_PASSWORD=your_checkpoint_password
CHECKPOINT_API_KEY=your_checkpoint_api_key

# Palo Alto Configuration
PALO_ALTO_BASE_URL=https://paloalto.company.com
PALO_ALTO_USERNAME=admin
PALO_ALTO_PASSWORD=your_palo_alto_password
PALO_ALTO_API_KEY=your_palo_alto_api_key

# CrowdStrike Configuration
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com
CROWDSTRIKE_CLIENT_ID=your_crowdstrike_client_id
CROWDSTRIKE_CLIENT_SECRET=your_crowdstrike_client_secret

# Imperva Configuration
IMPERVA_BASE_URL=https://imperva.company.com
IMPERVA_USERNAME=admin
IMPERVA_PASSWORD=your_imperva_password
IMPERVA_API_KEY=your_imperva_api_key

# Tenable Configuration
TENABLE_BASE_URL=https://cloud.tenable.com
TENABLE_ACCESS_KEY=your_tenable_access_key
TENABLE_SECRET_KEY=your_tenable_secret_key

# Report Configuration
COMPANY_NAME=Your Company Name
LOGO_PATH=path/to/your/logo.png

# Health Check Thresholds
CRITICAL_ERRORS_THRESHOLD=5
FAILED_LOGINS_THRESHOLD=10
FIREWALL_ALERTS_THRESHOLD=3
VULNERABILITY_HIGH_THRESHOLD=2
VULNERABILITY_CRITICAL_THRESHOLD=1